{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Resume Schema",
	"type": "array",
	"items": {
		"type": "object",
		"required": ["company", "roles"],
		"properties": {
			"company": {
				"type": "string",
				"description": "Company name"
			},
			"roles": {
				"type": "array",
				"minItems": 1,
				"items": {
					"type": "object",
					"required": ["title", "start"],
					"properties": {
						"title": {
							"type": "string",
							"description": "Job title"
						},
						"description": {
							"type": ["string", "null"],
							"description": "Role description"
						},
						"start": {
							"type": "string",
							"description": "Start date (e.g., 'August 2025')"
						},
						"end": {
							"type": "string",
							"description": "End date (e.g., 'Present', 'July 2025')"
						}
					}
				}
			}
		}
	}
}
